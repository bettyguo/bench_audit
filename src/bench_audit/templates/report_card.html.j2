<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>bench-audit report card — {{ m.name }} × {{ r.probe_name }}</title>
<style>
@page { size: Letter; margin: 0.6in; }
* { box-sizing: border-box; }
body { font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; font-size: 10.5pt; color: #1a1a1a; line-height: 1.4; }
h1 { font-size: 16pt; margin: 0 0 0.2em 0; }
.sub { color: #555; font-size: 10pt; margin-bottom: 1em; }
.verdict { display: inline-block; padding: 0.18em 0.6em; border-radius: 4px; font-weight: bold; font-size: 11pt; }
.verdict-pass { background: #d3f1d8; color: #0a5a1f; }
.verdict-fail { background: #fbd4d4; color: #82181c; }
.verdict-inconclusive { background: #f1ecd3; color: #5a4f0a; }
table { width: 100%; border-collapse: collapse; margin: 0.8em 0; font-size: 9.5pt; }
th, td { text-align: left; padding: 0.32em 0.5em; border-bottom: 1px solid #e3e3e3; vertical-align: top; }
th { width: 30%; background: #fafafa; }
.metric { font-size: 14pt; font-weight: bold; }
.ci-bar { background: #eee; height: 8px; border-radius: 4px; position: relative; margin: 0.4em 0; }
.ci-bar .fill { background: #2a6df4; height: 8px; border-radius: 4px; position: absolute; }
code { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; font-size: 9pt; }
.notes { background: #f8f8f8; border-left: 3px solid #ccc; padding: 0.6em 0.9em; margin-top: 0.5em; font-size: 8.8pt; white-space: pre-wrap; }
.caveat { background: #fff5ce; border-left: 3px solid #d9b400; padding: 0.5em 0.8em; margin-top: 0.5em; font-size: 9pt; }
.footer { color: #888; font-size: 8pt; margin-top: 0.8em; border-top: 1px solid #eaeaea; padding-top: 0.4em; }
</style>
</head>
<body>

<h1>{{ m.name }} × {{ r.probe_name }}{% if r.model_name %} × {{ r.model_name }}{% endif %}</h1>
<div class="sub">bench-audit report card &middot; harness {{ r.harness_version }} &middot; {{ r.timestamp }}</div>

<p>
<span class="verdict verdict-{{ r.verdict }}">{{ r.verdict|upper }}</span>
&nbsp;&nbsp;
<span class="metric">{{ "%.4f"|format(r.effect_size) }}</span>
<span style="color:#555;">&nbsp;{{ r.effect_size_kind }}</span>
</p>

<div class="ci-bar">
<div class="fill" style="left: {{ (r.ci_low * 100)|round(2) }}%; width: {{ ((r.ci_high - r.ci_low) * 100)|round(2) }}%;"></div>
</div>
<p style="font-size:9pt; color:#444;">
95% {{ r.ci_method }} CI: [{{ "%.4f"|format(r.ci_low) }}, {{ "%.4f"|format(r.ci_high) }}] &middot; n = {{ r.sample_size }}
</p>

<table>
<tr><th>Adapter</th><td><code>{{ r.adapter_name }}@{{ r.adapter_version }}</code></td></tr>
<tr><th>Benchmark version</th><td><code>{{ r.benchmark_version }}</code></td></tr>
<tr><th>Probe</th><td><code>{{ r.probe_name }}@{{ r.probe_version }}</code></td></tr>
{% if r.model_name %}
<tr><th>Model</th><td><code>{{ r.model_name }}@{{ r.model_version }}</code></td></tr>
{% endif %}
<tr><th>Eval-set SHA-256</th><td><code>{{ r.test_set_hash[:16] }}…</code></td></tr>
<tr><th>License</th><td>{{ m.license }}</td></tr>
<tr><th>Source</th><td><code>{{ m.source_url }}</code></td></tr>
{% if m.contamination_statement_url %}
<tr><th>Contamination statement</th><td><code>{{ m.contamination_statement_url }}</code></td></tr>
{% endif %}
<tr><th>Reproduction</th><td><code>{{ report.reproduction_command }}</code></td></tr>
</table>

<p><strong>Interpretation:</strong> {{ report.interpretation }}</p>

{% if r.allow_small_n or r.allow_wide_ci %}
<div class="caveat">
<strong>Caveats:</strong>
<ul style="margin: 0.2em 0 0 1.2em;">
{% if r.allow_small_n %}<li>Verdict issued with <code>allow_small_n=True</code> (n={{ r.sample_size }} &lt; 30).</li>{% endif %}
{% if r.allow_wide_ci %}<li>Verdict issued with <code>allow_wide_ci=True</code> (half-width {{ "%.3f"|format(r.ci_half_width) }} &gt; 0.1).</li>{% endif %}
</ul>
</div>
{% endif %}

{% if r.notes %}
<div class="notes">{{ r.notes }}</div>
{% endif %}

<div class="footer">
Generated by bench-audit. To reproduce: <code>{{ report.reproduction_command }}</code>.
</div>

</body>
</html>
