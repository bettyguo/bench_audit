* { box-sizing: border-box; }
body { font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", sans-serif; color: #181818; margin: 0 auto; padding: 2em 2em 4em; max-width: 1200px; line-height: 1.45; }
header h1 { margin: 0 0 0.2em; font-size: 1.8em; }
.subtitle { color: #555; margin: 0 0 0.3em; }
.meta { color: #888; font-size: 0.9em; margin: 0 0 1.5em; }
a { color: #2a6df4; text-decoration: none; }
a:hover { text-decoration: underline; }

table.matrix { border-collapse: collapse; width: 100%; font-size: 0.9em; }
table.matrix th, table.matrix td { border: 1px solid #e3e3e3; padding: 0; }
table.matrix thead th { padding: 0.45em 0.7em; background: #fafafa; text-align: left; font-weight: 600; }
table.matrix tbody th { padding: 0.45em 0.7em; background: #fafafa; text-align: left; font-weight: 600; }
.cell { padding: 0; text-align: center; }
.cell a { display: block; padding: 0.5em 0.3em; text-decoration: none; color: inherit; }
.cell a:hover { background: #f4f7ff; }
.cell-effect { font-weight: 700; font-size: 1.1em; }
.cell-ci { font-size: 0.78em; color: #555; }
.cell-n { font-size: 0.72em; color: #888; }
.cell.empty { color: #bbb; }

.verdict-pass { background: #ecf9ee; }
.verdict-fail { background: #fce9e9; }
.verdict-inconclusive { background: #f9f4dc; }

table.list { border-collapse: collapse; width: 100%; margin-top: 1em; }
table.list th, table.list td { padding: 0.4em 0.7em; border-bottom: 1px solid #ececec; text-align: left; font-size: 0.92em; }
table.list thead th { background: #fafafa; }

footer { margin-top: 2em; color: #777; font-size: 0.88em; border-top: 1px solid #eee; padding-top: 0.7em; }
code { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; background: #f4f4f4; padding: 0.05em 0.3em; border-radius: 3px; font-size: 0.9em; }
